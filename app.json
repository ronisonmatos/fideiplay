{
  "expo": {
    "name": "SantosPlay",
    "slug": "fideiplay",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo_SantosPlay.png",
    "scheme": "fideiplay",
    "userInterfaceStyle": "automatic",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#208AEF"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/logo_SantosPlay.png",
            "imageWidth": 200
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
