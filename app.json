{
  "expo": {
    "name": "SantosPlay",
    "slug": "fideiplay",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "santosplay",
    "userInterfaceStyle": "automatic",
    "android": {
      "package": "com.ronison.santosplay",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#26215C",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "notification": {
        "icon": "./assets/images/notification-icon.png",
        "color": "#26215C"
      },
      "predictiveBackGestureEnabled": false,
      "enableProguardInReleaseBuilds": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/audio/church_bell.wav",
            "./assets/audio/chat_beep.wav"
          ]
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#26215C",
          "android": {
            "image": "./assets/images/logo_SantosPlay.png",
            "imageWidth": 200
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a7cd055d-5cfe-4f9f-a8af-37bb94f0dc51"
      }
    },
    "owner": "ronison"
  }
}
